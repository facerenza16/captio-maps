{
  "manifest_version": 3,
  "name": "Captio Genie",
  "version": "1.1.0",
  "description": "Guardá los negocios que ves en Google Maps y exportalos a Excel o CSV en un clic.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://www.google.com/maps/*"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.google.com/maps/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
